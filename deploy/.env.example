# Crosswind Configuration

# ===== Security (Required) =====

# Encryption key for storing agent credentials securely
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-256-bit-hex-key-here

# API key for authenticating requests to the Crosswind platform
# Generate with: openssl rand -base64 32
CROSSWIND_API_KEY=your-crosswind-api-key-here

# LLM API Keys (at least one required for API analyzer and judgment)
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk-your-groq-key

# Optional: ClickHouse for analytics (uncomment to enable)
# CLICKHOUSE_ENABLED=true
# CLICKHOUSE_HOST=clickhouse:9000
# CLICKHOUSE_DATABASE=agent_eval
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# Optional: Docs authentication
# DOCS_USERNAME=admin
# DOCS_PASSWORD=your-docs-password
