# The Mastermind - Configuration
# Copy to .env and customize

# LLM Provider: "mock" (default), "openai", or "groq"
LLM_PROVIDER=mock

# API Keys (only needed if not using mock mode)
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=sk-your-key-here 

# Model to use (default: gpt-4o-mini)
MODEL=gpt-4o-mini

# Server port (default: 8901)
PORT=8901

# API Key for authentication (default: mastermind-secret-key)
API_KEY=mastermind-secret-key
