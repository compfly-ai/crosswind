# The Gadget - Configuration
# Copy to .env and customize

# Server port (default: 8902)
PORT=8902

# Note: The Gadget runs in mock mode only (no LLM needed for tools)
# Each tool has its own logic for calculations, conversions, etc.

AGENT_ID=the-gadget-001

# Crosswind API key to run evals
CROSSWIND_API_KEY=your-crosswind-api-key