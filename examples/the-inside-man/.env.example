# The Inside Man - Configuration
# Copy to .env and customize

# Server port (default: 8903)
PORT=8903

# Host for agent card URL (default: localhost)
HOST=localhost

# API Key for authentication (optional - leave empty for no auth)
API_KEY=inside-man-secret-key

# Crosswind API key to run evals
CROSSWIND_API_KEY=your-crosswind-api-key